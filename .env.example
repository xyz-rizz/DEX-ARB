# DEX Arbitrage Bot — Environment Template
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.

# ── RPC Endpoints ─────────────────────────────────────────────────────────────
BASE_RPC_URL=https://api.developer.coinbase.com/rpc/v1/base/YOUR_CDP_KEY
DRPC_RPC_URL=https://lb.drpc.live/base/YOUR_DRPC_KEY
ALCHEMY_EXEC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Wallet ────────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x...

# ── Contract (written by deploy/deploy.py) ────────────────────────────────────
ARB_EXECUTOR_ADDRESS=

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
EXECUTE_MODE=false
DRY_RUN=true
MIN_NET_PROFIT_USD=10.0
MIN_SPREAD_PCT=0.08
SCAN_INTERVAL_SECONDS=2
MAX_FLASH_LOAN_USDC=50000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=logs
